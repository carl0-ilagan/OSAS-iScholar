    rules_version = '2';
    service cloud.firestore {
      match /databases/{database}/documents {
        function isAuthenticated() {
          return request.auth != null;
        }

        function isSuperAdmin() {
          return isAuthenticated() && (
            request.auth.token.email == "contact.ischolar@gmail.com" ||
            request.auth.token.email == "mocas.support@gmail.com"
          );
        }

        function isCampusAdmin() {
          return isAuthenticated() &&
            (
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "campus_admin" ||
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.appRole == "campus_admin" ||
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "campusAdmin" ||
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.appRole == "campusAdmin"
            );
        }

        function sameCampus(campus) {
          return isCampusAdmin() &&
            campus != null &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.campus == campus;
        }

        function sameCampusByUserId(userId) {
          return isCampusAdmin() &&
            userId != null &&
            get(/databases/$(database)/documents/users/$(userId)).data.campus ==
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.campus;
        }

        function userCampus() {
          return isAuthenticated()
            ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.campus
            : null;
        }

        function sameUserCampus(campus) {
          return isAuthenticated() &&
            campus != null &&
            userCampus() == campus;
        }

        function sameRoomCreatorCampus(roomId) {
          return isAuthenticated() &&
            sameCampusByUserId(get(/databases/$(database)/documents/consultation_rooms/$(roomId)).data.createdBy);
        }

        // Users collection - users can read/write their own document
        match /users/{userId} {
          // Allow read if user is authenticated and reading their own document, or if admin
          allow read: if isAuthenticated() && (
            request.auth.uid == userId ||
            isSuperAdmin() ||
            sameCampus(resource.data.campus)
          );
          
          // Allow write (create/update) if user is authenticated and writing their own document, or if admin
          allow write: if isAuthenticated() && (
            request.auth.uid == userId ||
            isSuperAdmin()
          );
        }
        
        // Settings collection - branding settings
        match /settings/{settingId} {
          // Allow read for all users (including unauthenticated for landing page)
          allow read: if true;
          
          // Allow write only for super admins
          allow write: if isSuperAdmin();
        }
        
        // Verifications collection - student verification requests
        match /verifications/{verificationId} {
          // Allow read if user is authenticated and reading their own verification
          allow read: if request.auth != null && (
            request.auth.uid == resource.data.userId ||
            isSuperAdmin()
          );
          
          // Allow create if user is authenticated and creating their own verification
          allow create: if request.auth != null && 
                        request.auth.uid == request.resource.data.userId;
          
          // Allow update only for admin (to change status)
          allow update: if request.auth != null && 
                        isSuperAdmin();
          
          // Allow delete only for admin
          allow delete: if request.auth != null && 
                        isSuperAdmin();
        }

        // Applications collection - scholarship applications
        match /applications/{applicationId} {
          // Allow read if user is authenticated and reading their own application, or if admin
          allow read: if request.auth != null && (
            request.auth.uid == resource.data.userId ||
            isSuperAdmin() ||
            sameCampusByUserId(resource.data.userId) ||
            sameCampus(resource.data.campus)
          );
          
          // Allow create if user is authenticated and creating their own application
          allow create: if request.auth != null && 
                        request.auth.uid == request.resource.data.userId &&
                        request.resource.data.userId == request.auth.uid;
          
          // Allow update only for admin (to change status)
          allow update: if request.auth != null && (
                        isSuperAdmin() ||
                        sameCampusByUserId(resource.data.userId) ||
                        sameCampus(resource.data.campus)
                      );
          
          // Allow delete only for admin
          allow delete: if request.auth != null && (
                        isSuperAdmin() ||
                        sameCampusByUserId(resource.data.userId) ||
                        sameCampus(resource.data.campus)
                      );
        }

        // Scholarships collection - scholarship programs
        match /scholarships/{scholarshipId} {
          // Any authenticated user can read scholarships
          // (student apply + testimonial scholarship picker depend on this).
          allow read: if request.auth != null;
          
          // Campus admin is the owner of scholarship setup/changes per campus.
          // Super admin remains monitoring-only for this collection.
          allow create: if request.auth != null &&
                        sameCampus(request.resource.data.campus);
          allow update, delete: if request.auth != null &&
                                sameCampus(resource.data.campus);
          
          // Allow students to update slots field only (for application slot decrement)
          allow update: if request.auth != null &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['slots']) &&
                      request.resource.data.slots is int &&
                      request.resource.data.slots >= 0 &&
                      request.resource.data.slots < resource.data.slots;
        }

        // Announcements collection
        match /announcements/{announcementId} {
          // Allow read for all authenticated users
          allow read: if request.auth != null;
          
          // Allow write only for admin
          allow write: if request.auth != null && 
                      isSuperAdmin();
        }

        // Feedback collection
        match /feedback/{feedbackId} {
          // Allow read if user is reading their own feedback, or if admin
          allow read: if request.auth != null && (
            resource.data.userId == request.auth.uid ||
            isSuperAdmin()
          );
          
          // Allow create for authenticated users
          allow create: if request.auth != null && 
                        request.resource.data.userId == request.auth.uid;
        }

        // Testimonials collection
        match /testimonials/{testimonialId} {
          // Keep landing page public and allow authenticated users (including campus admins) to read all testimonials.
          allow read: if true;
          
          // Allow create for authenticated users
          allow create: if request.auth != null && 
                        request.resource.data.userId == request.auth.uid;
          
          // Super admin can manage all; campus admin can manage testimonials from own campus users
          allow update, delete: if request.auth != null && (
                                isSuperAdmin() ||
                                sameCampusByUserId(resource.data.userId) ||
                                sameCampus(resource.data.campus)
                              );
        }

        // Document Requirements collection - requirements set by admin
        match /documentRequirements/{requirementId} {
          // Campus-scoped read access
          allow read: if request.auth != null && (
            isSuperAdmin() ||
            sameUserCampus(resource.data.campus) ||
            sameCampusByUserId(resource.data.createdBy)
          );
          
          // Campus admin creates requirements for own campus; super admin can create globally
          allow create: if request.auth != null && (
            isSuperAdmin() ||
            (
              request.resource.data.createdBy == request.auth.uid &&
              sameCampus(request.resource.data.campus)
            )
          );

          // Updates/deletes are campus-scoped to the owning campus
          allow update: if request.auth != null && (
            isSuperAdmin() ||
            (
              sameCampus(resource.data.campus) &&
              request.resource.data.campus == resource.data.campus
            )
          );
          allow delete: if request.auth != null && (
            isSuperAdmin() ||
            sameCampus(resource.data.campus)
          );
          
          // Sample chunks subcollection for large PDF files
          match /sampleChunks/{chunkId} {
            // Inherit campus scoping via parent requirement
            allow read: if request.auth != null && (
              isSuperAdmin() ||
              sameUserCampus(get(/databases/$(database)/documents/documentRequirements/$(requirementId)).data.campus) ||
              sameCampusByUserId(get(/databases/$(database)/documents/documentRequirements/$(requirementId)).data.createdBy)
            );
            
            allow write: if request.auth != null && (
              isSuperAdmin() ||
              sameCampus(get(/databases/$(database)/documents/documentRequirements/$(requirementId)).data.campus)
            );
          }
        }

        // Student Documents collection - documents uploaded by students
        match /studentDocuments/{documentId} {
          // Allow read if user is reading their own document, or if admin
          allow read: if request.auth != null && (
            resource.data.userId == request.auth.uid ||
            isSuperAdmin() ||
            sameCampusByUserId(resource.data.userId)
          );
          
          // Allow create if user is authenticated and creating their own document
          allow create: if request.auth != null && 
                        request.resource.data.userId == request.auth.uid;
          
          // Allow update if user is updating their own document, or if admin
          allow update: if request.auth != null && (
            resource.data.userId == request.auth.uid ||
            isSuperAdmin() ||
            sameCampusByUserId(resource.data.userId)
          );
          
          // Allow delete if user is deleting their own document, or if admin
          allow delete: if request.auth != null && (
            resource.data.userId == request.auth.uid ||
            isSuperAdmin() ||
            sameCampusByUserId(resource.data.userId)
          );
          
          // Chunks subcollection for large files
          match /chunks/{chunkId} {
            // Allow read if user owns the parent document, or if admin
            allow read: if request.auth != null && (
              get(/databases/$(database)/documents/studentDocuments/$(documentId)).data.userId == request.auth.uid ||
              isSuperAdmin() ||
              sameCampusByUserId(get(/databases/$(database)/documents/studentDocuments/$(documentId)).data.userId)
            );
            
            // Allow write if user owns the parent document, or if admin
            allow write: if request.auth != null && (
              get(/databases/$(database)/documents/studentDocuments/$(documentId)).data.userId == request.auth.uid ||
              isSuperAdmin() ||
              sameCampusByUserId(get(/databases/$(database)/documents/studentDocuments/$(documentId)).data.userId)
            );
          }
        }

        // Student Profile Forms collection - profile forms submitted by students
        match /studentProfileForms/{formId} {
          // Allow read if user is reading their own form, or if admin
          allow read: if request.auth != null && (
            resource.data.userId == request.auth.uid ||
            isSuperAdmin() ||
            sameCampusByUserId(resource.data.userId)
          );
          
          // Allow create if user is authenticated and creating their own form
          allow create: if request.auth != null && 
                        request.resource.data.userId == request.auth.uid;
          
          // Allow update if user is updating their own form, or if admin
          allow update: if request.auth != null && (
            resource.data.userId == request.auth.uid ||
            isSuperAdmin() ||
            sameCampusByUserId(resource.data.userId)
          );
          
          // Allow delete only for admin
          allow delete: if request.auth != null && 
                        isSuperAdmin();
        }

        // Application Forms collection - application forms submitted by students
        match /applicationForms/{formId} {
          // Allow read if user is reading their own form, or if admin
          allow read: if request.auth != null && (
            resource.data.userId == request.auth.uid ||
            isSuperAdmin() ||
            sameCampusByUserId(resource.data.userId)
          );
          
          // Allow create if user is authenticated and creating their own form
          allow create: if request.auth != null && 
                        request.resource.data.userId == request.auth.uid;
          
          // Allow update if user is updating their own form, or if admin
          allow update: if request.auth != null && (
            resource.data.userId == request.auth.uid ||
            isSuperAdmin() ||
            sameCampusByUserId(resource.data.userId)
          );
          
          // Allow delete only for admin
          allow delete: if request.auth != null && 
                        isSuperAdmin();
        }

        // Dynamic PDF forms managed by admin
        match /forms/{formId} {
          // Authenticated users can read forms inside the system
          allow read: if request.auth != null;

          // Only admin can create/update/delete forms
          allow create, update, delete: if request.auth != null &&
                                        isSuperAdmin();
        }

        // PDF template chunks (stored in Firestore to avoid Firebase Storage dependency)
        match /form_pdf_chunks/{chunkId} {
          // Authenticated users can read chunk data to render PDF in-app
          allow read: if request.auth != null;

          // Only admin can create/update/delete chunk documents
          allow create, update, delete: if request.auth != null &&
                                        isSuperAdmin();
        }

        // Field definitions for each dynamic PDF form
        match /form_fields/{fieldId} {
          // Authenticated users can read fields to render overlays
          allow read: if request.auth != null;

          // Only admin can create/update/delete fields
          allow create, update, delete: if request.auth != null &&
                                        isSuperAdmin();
        }

        // Student submissions metadata
        match /submissions/{submissionId} {
          // Student can create only for their own uid; admin can create if needed
          allow create: if request.auth != null && (
            isSuperAdmin() ||
            sameCampusByUserId(request.resource.data.studentId) ||
            sameCampus(request.resource.data.campus) ||
            request.resource.data.studentId == request.auth.uid
          );

          // Student can read own submissions, admin can read all
          allow read: if request.auth != null && (
            isSuperAdmin() ||
            sameCampusByUserId(resource.data.studentId) ||
            sameCampus(resource.data.campus) ||
            resource.data.studentId == request.auth.uid
          );

          // Owner student may update own submission (e.g. valuesByFieldName after saving field values); admins as before
          allow update: if request.auth != null && (
            isSuperAdmin() ||
            sameCampusByUserId(resource.data.studentId) ||
            sameCampus(resource.data.campus) ||
            resource.data.studentId == request.auth.uid
          );

          allow delete: if request.auth != null && (
            isSuperAdmin() ||
            sameCampusByUserId(resource.data.studentId) ||
            sameCampus(resource.data.campus) ||
            resource.data.studentId == request.auth.uid
          );
        }

        // Values for each field in a submission
        match /submission_values/{valueId} {
          // Student can create values only under their own submission; admin can create/read/update/delete
          allow create: if request.auth != null && (
            isSuperAdmin() ||
            sameCampusByUserId(get(/databases/$(database)/documents/submissions/$(request.resource.data.submissionId)).data.studentId) ||
            sameCampus(get(/databases/$(database)/documents/submissions/$(request.resource.data.submissionId)).data.campus) ||
            get(/databases/$(database)/documents/submissions/$(request.resource.data.submissionId)).data.studentId == request.auth.uid
          );

          // Read own values through submission ownership, or as admin
          allow read: if request.auth != null && (
            isSuperAdmin() ||
            sameCampusByUserId(get(/databases/$(database)/documents/submissions/$(resource.data.submissionId)).data.studentId) ||
            sameCampus(get(/databases/$(database)/documents/submissions/$(resource.data.submissionId)).data.campus) ||
            get(/databases/$(database)/documents/submissions/$(resource.data.submissionId)).data.studentId == request.auth.uid
          );

          // Student owner may update/delete own submission field values; admins/campus as before
          allow update, delete: if request.auth != null && (
            isSuperAdmin() ||
            sameCampusByUserId(get(/databases/$(database)/documents/submissions/$(resource.data.submissionId)).data.studentId) ||
            sameCampus(get(/databases/$(database)/documents/submissions/$(resource.data.submissionId)).data.campus) ||
            get(/databases/$(database)/documents/submissions/$(resource.data.submissionId)).data.studentId == request.auth.uid
          );
        }

        // Consultation rooms for campus-admin video consult scheduling
        match /consultation_rooms/{roomId} {
          // Any authenticated user from same campus can read room list/details.
          allow read: if request.auth != null && (
            isSuperAdmin() ||
            sameUserCampus(resource.data.campus) ||
            sameCampusByUserId(resource.data.createdBy)
          );

          // Room creation is campus-admin scoped to own campus.
          allow create: if request.auth != null && (
            isSuperAdmin() ||
            sameCampus(request.resource.data.campus)
          );

          // Update:
          // - super admin
          // - campus admin of same campus
          // - student from same campus only for join/call signaling fields
          allow update: if request.auth != null && (
            isSuperAdmin() ||
            sameCampus(resource.data.campus) ||
            sameCampusByUserId(resource.data.createdBy) ||
            (
              (sameUserCampus(resource.data.campus) || sameCampusByUserId(resource.data.createdBy)) &&
              (
                resource.data.joinedStudentId == request.auth.uid ||
                (resource.data.joinedStudentId == null && request.resource.data.joinedStudentId == request.auth.uid)
              ) &&
              request.resource.data.campus == resource.data.campus &&
              request.resource.data.createdBy == resource.data.createdBy &&
              request.resource.data.createdAt == resource.data.createdAt &&
              request.resource.data.roomName == resource.data.roomName &&
              request.resource.data.durationMinutes == resource.data.durationMinutes &&
              request.resource.data.expiresAt == resource.data.expiresAt
            )
          );

          // Delete remains admin-only.
          allow delete: if request.auth != null && (
            isSuperAdmin() ||
            sameCampus(resource.data.campus)
          );

          // WebRTC ICE candidates for caller/admin side
          match /offerCandidates/{candidateId} {
            allow read, create: if request.auth != null && (
              isSuperAdmin() ||
              sameUserCampus(get(/databases/$(database)/documents/consultation_rooms/$(roomId)).data.campus) ||
              sameRoomCreatorCampus(roomId)
            );
            allow update, delete: if request.auth != null && (
              isSuperAdmin() ||
              sameCampus(get(/databases/$(database)/documents/consultation_rooms/$(roomId)).data.campus) ||
              sameRoomCreatorCampus(roomId)
            );
          }

          // WebRTC ICE candidates for callee/student side
          match /answerCandidates/{candidateId} {
            allow read, create: if request.auth != null && (
              isSuperAdmin() ||
              sameUserCampus(get(/databases/$(database)/documents/consultation_rooms/$(roomId)).data.campus) ||
              sameRoomCreatorCampus(roomId)
            );
            allow update, delete: if request.auth != null && (
              isSuperAdmin() ||
              sameCampus(get(/databases/$(database)/documents/consultation_rooms/$(roomId)).data.campus) ||
              sameRoomCreatorCampus(roomId)
            );
          }

          // Consultation room chat messages
          match /messages/{messageId} {
            allow read, create: if request.auth != null && (
              isSuperAdmin() ||
              sameUserCampus(get(/databases/$(database)/documents/consultation_rooms/$(roomId)).data.campus) ||
              sameRoomCreatorCampus(roomId)
            );
            allow update, delete: if request.auth != null && (
              isSuperAdmin() ||
              sameCampus(get(/databases/$(database)/documents/consultation_rooms/$(roomId)).data.campus) ||
              sameRoomCreatorCampus(roomId) ||
              resource.data.senderId == request.auth.uid
            );
          }

          // Student join approval requests
          match /join_requests/{requestId} {
            allow read: if request.auth != null && (
              isSuperAdmin() ||
              request.auth.uid == requestId ||
              sameCampus(get(/databases/$(database)/documents/consultation_rooms/$(roomId)).data.campus) ||
              sameRoomCreatorCampus(roomId)
            );
            allow create: if request.auth != null &&
              request.auth.uid == requestId &&
              request.resource.data.userId == request.auth.uid &&
              request.resource.data.status == "pending" &&
              (
                isSuperAdmin() ||
                sameUserCampus(get(/databases/$(database)/documents/consultation_rooms/$(roomId)).data.campus) ||
                sameRoomCreatorCampus(roomId)
              );
            allow update, delete: if request.auth != null && (
              isSuperAdmin() ||
              sameCampus(get(/databases/$(database)/documents/consultation_rooms/$(roomId)).data.campus) ||
              sameRoomCreatorCampus(roomId)
            );
          }
        }
      }
    }

